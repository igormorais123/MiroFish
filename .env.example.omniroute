# Mirofish INTEIA — template com combos OmniRoute especializados por tarefa
# Copie para .env e substitua <SUA_KEY_NOVA> quando gerar key no painel.

APP_NAME=MiroFish-Inteia
APP_CODE=mirofish-inteia

# ===== OmniRoute (gateway INTEIA) =====
OMNIROUTE_URL=https://omniroute.srv1354997.hstgr.cloud
OMNIROUTE_API_KEY=<SUA_KEY_NOVA>

LLM_API_KEY=<SUA_KEY_NOVA>
LLM_BASE_URL=https://omniroute.srv1354997.hstgr.cloud/v1
LLM_MODEL_NAME=sonnet-tasks
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# Combos especializados por tarefa Mirofish (Helena decidiu):
#   - ontologia          -> Sonnet: raciocinio estruturado, ontologia robusta
#   - graph-extract      -> Haiku : volume alto de chunks, latencia importa
#   - agent-profile      -> Haiku : geracao em lote (15+ perfis)
#   - simulation-config  -> Sonnet: config social precisa consistencia
#   - report-section     -> Sonnet: redacao de secao + tool-use
#   - helena-strategos   -> Opus  : sintese estrategica final (qualidade maxima)
LLM_MODEL_ALIASES={"helena-premium":"cc/claude-opus-4-6","sonnet-tasks":"cc/claude-sonnet-4-6","opus-tasks":"cc/claude-opus-4-6","haiku-tasks":"cc/claude-haiku-4-5"}

# Roteamento por subsistema (o Mirofish le estas keys)
LLM_AGENT_MODEL=haiku-tasks       # agentes OASIS + volume
LLM_PREMIUM_MODEL=sonnet-tasks    # ontologia, sim-config, relatorio
LLM_HELENA_MODEL=helena-premium   # analise estrategica final

# ===== Graphiti / Neo4j =====
GRAPHITI_BASE_URL=http://localhost:8003
GRAPHITI_TIMEOUT=180
GRAPHITI_MODEL=sonnet-tasks
NEO4J_PASSWORD=mirofish2026

# ===== Apify enrichment opcional =====
APIFY_API_TOKEN=<SUA_APIFY_TOKEN>
APIFY_ENRICH_TIMEOUT_SECONDS=45
COLMEIA_SCRIPTS_PATH=

# ===== Supabase opcional =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=<SUA_SUPABASE_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<SUA_SUPABASE_SERVICE_ROLE_KEY>

# ===== Dados locais =====
MIROFISH_DATA_DIR=data

# ===== Auth =====
INTERNAL_API_TOKEN=mirofish-inteia-local-2026

# ===== Flask =====
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
