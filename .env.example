# ===== Flask/backend =====
# Em producao mantenha debug desligado e gere SECRET_KEY unica no cofre do ambiente.
FLASK_DEBUG=false
FLASK_HOST=127.0.0.1
FLASK_PORT=5001
SECRET_KEY=change_me_generate_a_long_random_secret

# Origens autorizadas para chamadas cross-origin ao backend.
# O site publico em mesmo dominio nao precisa de CORS, mas previews/dev podem precisar.
CORS_ORIGINS=https://inteia.com.br,https://mirofish-inteia.vercel.app,http://localhost:3000,http://127.0.0.1:3000

# Configuracao da API LLM
# Padrao recomendado na INTEIA: OmniRoute
# Se OMNIROUTE_* estiver configurado, o backend passa a priorizar esse gateway.
OMNIROUTE_URL=https://omniroute.seu-dominio.com
OMNIROUTE_API_KEY=your_omniroute_api_key_here

# Fallback compativel com OpenAI
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=haiku-tasks

# Aliases opcionais de modelo
# Formato JSON ou CSV simples:
# LLM_MODEL_ALIASES={"helena-premium":"cc/claude-sonnet-4-6","haiku-tasks":"cc/claude-haiku-4-5"}
LLM_MODEL_ALIASES=
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=3

# ===== Graphiti Server (grafo de memoria temporal) =====
# URL do servidor Graphiti que substitui o Zep Cloud.
GRAPHITI_BASE_URL=http://localhost:8003
# Timeout em segundos para requisicoes ao Graphiti
GRAPHITI_TIMEOUT=60
# Se true, falha a construcao quando Graphiti estiver indisponivel.
# Se false, usa fallback local de esquema e fallback LLM na simulacao.
GRAPHITI_REQUIRED=false
# Modelo usado pelo Graphiti quando o servico estiver acoplado
GRAPHITI_MODEL=haiku-tasks

# ===== Zep legacy opcional =====
# Mantido apenas para compatibilidade com ambientes antigos. Graphiti e o caminho preferencial.
ZEP_BASE_URL=
ZEP_API_KEY=
ZEP_MODE=disabled
ZEP_REQUIRED=false

# ===== Apify enrichment opcional =====
# Usado pelo backend para Google SERP, Instagram e YouTube quando enriquecimento estiver habilitado.
APIFY_API_TOKEN=your_apify_token_here
APIFY_ENRICH_TIMEOUT_SECONDS=45
COLMEIA_SCRIPTS_PATH=

# ===== Supabase opcional =====
# Configure somente se o projeto passar a usar Supabase diretamente.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ===== Dados locais =====
MIROFISH_DATA_DIR=data

# ===== Auth entre servicos =====
# Token que o backend INTEIA envia para consumir a API interna do MiroFish-Inteia.
INTERNAL_API_TOKEN=change_me_internal_token

# ===== Configuracao opcional de LLM auxiliar =====
# Use isto para distribuir carga entre provedores ocidentais compativeis.
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_URL=https://api.cerebras.ai/v1
