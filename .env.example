# Configuracao da API LLM (qualquer provedor compativel com o formato OpenAI)
# Padrao recomendado: OpenAI com gpt-4o-mini
# Alternativas compativeis: OpenRouter, Azure OpenAI e gateways que exponham API no formato OpenAI
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# ===== Configuracao do grafo de memoria Zep =====
# Para uso simples, a franquia gratuita costuma ser suficiente: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Configuracao opcional de LLM auxiliar =====
# Use isto para distribuir carga entre provedores ocidentais compativeis.
# Exemplos comuns: OpenRouter, Groq, Azure OpenAI ou outro gateway compativel com a API da OpenAI.
# Se nao for usar uma configuracao auxiliar, remova ou deixe estas variaveis em branco.
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
